PORT=3000

# Choose one: gemini, openai, groq, or fallback
AI_PROVIDER=gemini
AI_FALLBACK_PROVIDER=groq

# Gemini server-side config
GEMINI_API_KEY=
# GOOGLE_API_KEY also works and takes precedence if both are set
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional OpenAI config
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional Groq config
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Optional news/image providers
NEWS_API_KEY=
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=
